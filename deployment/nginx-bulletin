# Nginx reverse proxy for Bulletin Board Flask server
# Place in /etc/nginx/sites-available/bulletin and symlink to sites-enabled
#
# Before using, replace the placeholders:
#   __SERVER_NAME__  → your hostname or IP
#   __FLASK_PORT__   → the port Flask listens on (default 5000)

server {
    listen 80;
    server_name __SERVER_NAME__;

    client_max_body_size 100M;

    location / {
        proxy_pass http://127.0.0.1:__FLASK_PORT__;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # WebSocket support
    location /socket.io {
        proxy_pass http://127.0.0.1:__FLASK_PORT__/socket.io;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 86400;
    }
}
